# mcp-xray environment - copy to `.env` and fill in.
#   cp .env.template .env
#
# `.env` is git-ignored. rerun.sh auto-loads it (repo root, then the profile
# dir - profile wins). Nothing here is required for an offline ESTIMATE run;
# every var has a sensible default. Set the API keys to unlock authoritative
# token counts and the behavioral LLM probes.

# --- LLM vendor & model -------------------------------------------------------
# The VENDOR IS INFERRED FROM THE MODEL ID - there is no separate vendor var.
#   claude*            -> Anthropic   (needs ANTHROPIC_API_KEY)
#   gpt* / o1 / o3 / o4 / chatgpt -> OpenAI (needs OPENAI_API_KEY)
# This single id drives token counting, the LLM probes, and price lookup.
MODEL=claude-opus-4-8

# Token backend: "offline" (heuristic ESTIMATE, no key) or "api" (authoritative,
# needs the matching key below). rerun.sh auto-selects "api" when a key is set.
TOKEN_BACKEND=offline

# Enable the behavioral LLM probes (tool-selection, confusability, and the
# vague-description confirmer). 1/true = on. Needs the matching API key.
LLM=0

# Tool-choice samples per behavioral probe. Higher = steadier Selection
# Robustness score (less run-to-run flicker), linearly more LLM calls. Empty
# uses the CLI default (3); 7 is a good balance for a committed profile capture.
SAMPLES=

# --- API keys (secrets - never commit) ---------------------------------------
# Anthropic: required for token-backend=api with a claude model, and for any
# LLM probe against a claude model.
ANTHROPIC_API_KEY=

# OpenAI: required only for LLM probes against a gpt/o-series model. (OpenAI
# token counting is local via tiktoken and needs no key.)
OPENAI_API_KEY=

# --- audited server (rerun.sh) -----------------------------------------------
# Path to the OrionBelt Analytics repo whose server.py we launch and audit.
MCP_REPO=../orionbelt-analytics

# Local port rerun.sh binds the server on (and audits over http://localhost:PORT/mcp).
PORT=9000

# --- networking ---------------------------------------------------------------
# User-Agent sent on the MCP HTTP/SSE handshake (some servers gate on it).
# MCP_XRAY_USER_AGENT=mcp-xray/0.x

# Extra HTTP header(s) for authed --http/--sse servers (e.g. OBSL >= 2.12.0).
# Equivalent to repeating --header on the CLI; one "Name: value" per line, so a
# multi-line value sets several headers. Keep the token here (git-ignored .env)
# rather than on the command line, where it would leak into ps/shell history.
# MCP_XRAY_HTTP_HEADER=Authorization: Bearer <token>
